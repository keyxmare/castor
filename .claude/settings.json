{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(make:*)",
      "Bash(docker compose:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git fetch:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git merge-base:*)",
      "Bash(git rev-parse:*)",
      "Read",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-main.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/commit-gate.sh"
          }
        ]
      }
    ]
  }
}
